    bmask = [(bands == band) for band in filters]
    args = (t, mag, emag, bmask)
    
    # mean / peak-to-peak amplitude
    m0_data, amp_data, _ = calculate_m0_amp(args) 
    
    tasks = []; k = 0
    seed_seq = np.random.SeedSequence(random_state)
    seeds = seed_seq.spawn(N_period * N_rep * N_tmpls)
    for tmpl_name, tmpl in templates.items(): #presuming template dictionary
        for _ in range(N_period):
            for _ in range(N_rep):
                tasks.append((tmpl_name, tmpl, seeds[k].generate_state(1)[0]))
                k+=1
    
    parallel = Parallel(n_jobs=n_jobs, return_as="generator", verbose=0)
    gen = parallel(delayed(synthetic_curve_analysis)(
            args, m0_data, amp_data, tmpl_name, tmpl,
            rng_seed=seed, sig_amp=sig_amp, n0=n0
        ) for tmpl_name, tmpl, seed in tasks
    )
    results = [res for res in tqdm(gen, total=len(tasks), disable=not verbose, desc="alias MC")]
    return pd.DataFrame(results)