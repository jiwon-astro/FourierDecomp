def synthetic_curve_analysis(args, m0_data, amp_data, tmpl_name, template,
                             rng_seed=None, sig_amp=0.1, n0=5, K=1, harmonics=1):
    rng = np.random.default_rng(rng_seed) # set seed
    
    t, mag, emag, bmask = args
    t0 = np.min(t)
    
    # random generated (Period, Epoch) - true value
    P_true = np.exp(rng.uniform(np.log(pmin), np.log(pmax))) # random period
    E_true = t0 + rng.uniform(0.0, P_true) # random epoch
    
    A_tmpl, Q_tmpl = template.A, template.Q
    mag_syn, amp_syn, scale = generate_synthetic_lc(args, m0_data, amp_data, P_true, E_true,
                                             A_tmpl, Q_tmpl, sig_amp=sig_amp, rng=rng)
    Ps, Zs = robust_period_search(t, mag_syn, emag, bands,
                                 n0=n0, K=K, harmonics=harmonics, plot=False)
    
    pidx = np.argmax(Zs)
    P_recon = Ps[pidx]; Z_recon = Zs[pidx]
    rel_err = (P_recon - P_true) / P_true
    
    rst = {'template': tmpl_name,
           'P_true': P_true,'E_true': E_true,
           'ampl_scale': scale,
           'P_recon': P_recon, 'Z_recon': Z_recon,
           'rel_err':rel_err}
    
    return rst

def monte_carlo_aliasing_analysis(sid, templates, mode=None,
                                  N_period = 200, N_rep = 5, n_jobs=12, 
                                  random_state=0, sig_amp = 0.1,
                                  verbose = False):
    cfg = get_data_config(mode)
    filters = cfg.filters; activated_bands = cfg.activated_bands; n_bands = cfg.n_bands
    
